# Frontend
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_public_anon_key

# Supabase service role is server-side only. Never expose in frontend.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# AI summarization. If absent, app uses extractive fallback summaries for demos.
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini

# News APIs. NewsAPI is optional because GDELT/RSS are public fallbacks.
NEWSAPI_KEY=your_newsapi_key

# Email automation.
RESEND_API_KEY=re_...
EMAIL_FROM="Morning Intelligence Brief <briefs@yourdomain.com>"

# Optional app controls.
DEFAULT_DELIVERY_TIME=07:00
APP_BASE_URL=https://your-netlify-site.netlify.app
