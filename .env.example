# Frontend (safe to expose anon Supabase key)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
VITE_APP_NAME=Morning Intelligence Brief

# Serverless functions (configure in Netlify environment variables)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
OPENAI_API_KEY=sk-your-openai-key
NEWSAPI_KEY=your-newsapi-key
RESEND_API_KEY=re_your-resend-key
RESEND_FROM=Morning Brief <briefs@yourdomain.com>
APP_BASE_URL=https://your-netlify-site.netlify.app
BRIEF_TIMEZONE=America/New_York
DEFAULT_DELIVERY_TIME=07:00
